  "events": [
    {
      "id": "sangu_maolu",
      "name": "三顾茅庐",
      "trigger_turn": [1, 15],
      "condition": "faction:liubei AND officer_in_wild:23",
      "effect": "officer:23 joins liubei",
      "narrative": "刘备三次拜访隆中草庐，终于得见卧龙诸葛亮。诸葛亮献上《隆中对》，分析天下大势，愿随刘备出山匡扶汉室。"
    },
    {
      "id": "caocao_south",
      "name": "曹操南征",
      "trigger_turn": [18, 24],
      "condition": "faction:caocao has_city:xiangyang",
      "effect": "liubiao faction collapses, jiangling joins caocao",
      "narrative": "建安十三年秋，曹操率大军南下。刘表病逝，其子刘琮举荆州投降曹操。"
    },
    {
      "id": "changban",
      "name": "长坂坡之战",
      "trigger_turn": [18, 24],
      "condition": "faction:caocao has_city:xiangyang AND faction:liubei alive",
      "effect": "liubei retreats, zhaoyun gains fame",
      "narrative": "曹操轻骑追击刘备于当阳长坂。赵云在乱军中七进七出，救出阿斗。张飞据水断桥，瞋目横矛，曹军无人敢近。"
    },
    {
      "id": "sunjian_alliance",
      "name": "孙刘同盟",
      "trigger_turn": [20, 30],
      "condition": "faction:liubei alive AND faction:sunquan alive AND faction:caocao has_city:xiangyang",
      "effect": "alliance between liubei and sunquan for 24 turns",
      "narrative": "曹操大军压境，诸葛亮出使江东，智激周瑜，舌战群儒，促成孙刘同盟。周公瑾挂帅，准备在赤壁迎击曹操。"
    },
    {
      "id": "chibi_fire",
      "name": "赤壁之战",
      "trigger_turn": [24, 36],
      "condition": "alliance:liubei-sunquan AND faction:caocao has_army_near:chibi",
      "effect": "massive fire damage to caocao's navy, morale collapse",
      "narrative": "东风起，黄盖诈降，火船冲向曹军水寨。顷刻间火光冲天，曹军战舰化为灰烬。周瑜挥军掩杀，曹操大败，率残军北逃。"
    },
    {
      "id": "huarong",
      "name": "华容道",
      "trigger_turn": [24, 36],
      "condition": "event:chibi_fire triggered",
      "effect": "Guan Yu encounters Cao Cao; choice: capture or release",
      "narrative": "曹操败走华容道，正遇关羽所部。关羽念及旧日恩情，犹豫不决……"
    }
  ]
